{
  "name": "xcoretech-disk-cleaner",
  "version": "1.3.6",
  "description": "Advanced PC optimizer and cleaner built with Electron",
  "main": "index.js",
  "author": "XCoreTech Team",
  "license": "Proprietary",
  "private": true,
  "scripts": {
    "start": "electron . --js-flags=\"--max-old-space-size=96 --optimize-for-size --gc-interval=100 --expose-gc\" --disable-gpu-sandbox",
    "pack": "electron-builder --dir",
    "predist": "node pre-dist.js",
    "dist": "electron-builder",
    "prerelease": "node pre-dist.js",
    "release": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.xcoretech.diskcleaner",
    "productName": "XCoreTech PC Optimizer",
    "publish": {
      "provider": "github",
      "owner": "mhmdrameez",
      "repo": "xcoretechelectron",
      "private": false
    },
    "releaseInfo": {
      "releaseNotesFile": "release-notes.md"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.js",
      "main.js",
      "config.js",
      "preload.js",
      "renderer.js",
      "scanner.js",
      "cleaner.js",
      "utils.js",
      "systemInfo.js",
      "analytics.js",
      "crashHandler.js",
      "location.js",
      "updater.js",
      "index.html",
      "styles.css",
      "assets/**/*"
    ],
    "asar": true,
    "compression": "maximum",
    "win": {
      "icon": "assets/app-icon.ico",
      "publisherName": "XCoreTech Team",
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "ia32",
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "XCoreTech PC Optimizer",
      "deleteAppDataOnUninstall": true,
      "license": "license.txt"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
